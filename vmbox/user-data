#cloud-config

users:
  - name: ansible
    gecos: Ansible User
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - ssh-rsa  user@Lennar
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPyf7lkbDVEUG9a7KJ0jGJky5Hi5Dmq4s1k7jRN6PZi7 Max
ssh_pwauth: true
disable_root: false

chpasswd:
  list: |
    root:root
    ansible:123
  expire: false

write_files:
  - path: /etc/ssh/sshd_config.d/99-root-login.conf
    permissions: '0644'
    content: |
      PermitRootLogin yes
      PasswordAuthentication yes

  - path: /etc/netplan/01-static.yaml
    permissions: '0644'
    content: |
      network:
        version: 2
        renderer: networkd
        ethernets:
          enp0s17:
            dhcp4: false
            addresses:
              - 10.0.2.230/24
            gateway4: 10.0.2.1
            nameservers:
              addresses:
                - 8.8.8.8

runcmd:
  - netplan apply
  - systemctl restart ssh
